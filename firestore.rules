rules_version = '2';

// WakeLock Firestore rules. Copy into Firebase Console → Firestore Database →
// Rules → Publish (or deploy with `firebase deploy --only firestore:rules`).
// Dev-oriented but not wide open: signed-in users can read profiles, but only
// write their own doc; usernames can't be stolen. Extend as social features land.
service cloud.firestore {
  match /databases/{database}/documents {

    // Public-ish profiles: any signed-in user can read (friends, leaderboard);
    // only the owner can write their own doc.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Username uniqueness index (doc id = the username, value = { uid }).
    // Anyone signed-in can look up; a user may only claim a name for themselves
    // and cannot overwrite a name already owned by someone else.
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // TODO (as features land): posts/{postId} (+comments,+reactions),
    // friend_requests, friendships, challenges/{id}, leaderboards.
  }
}
