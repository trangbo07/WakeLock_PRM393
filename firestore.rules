rules_version = '2';

// WakeLock Firestore rules.
//
// ⚠️ DEV MODE: any signed-in user can read/write any document. This keeps
// iteration fast while the social features (friends, feed, challenges, ...) are
// being built — no rule change needed per new collection.
//
// 🔒 BEFORE PRODUCTION: replace with per-collection rules (owner-only writes,
// friend-scoped reads). A stricter reference set is kept commented below.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

