rules_version = '2';

// WakeLock Cloud Storage rules. Copy into Firebase Console → Storage → Rules →
// Publish. Signed-in users can read any user asset (avatars, feed photos) but
// only write under their own users/{uid}/ path.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
